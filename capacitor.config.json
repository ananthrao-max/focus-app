{
  "appId": "app.getkeel",
  "appName": "Keel",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#0C0C12",
      "showSpinner": false,
      "launchFadeOutDuration": 300
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0C0C12"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#0C0C12",
    "preferredContentMode": "mobile"
  }
}
